---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = 'Merwan Birem — AI Innovation Leader. Computer Vision, Industrial AI & Autonomous Perception. 10+ years R&D experience, 20+ publications, leading 4M€ research programs at Flanders Make, Belgium.', wide = false } = Astro.props;

const B = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // always ends with /
const SITE = 'https://merwanski.github.io';
const CANONICAL = `${SITE}${Astro.url.pathname}`;
const PAGE_TITLE = title === 'Home' ? 'Merwan Birem' : `${title} — Merwan Birem`;

const nav = [
  { label: 'Now', href: `${B}now` },
  { label: 'Projects', href: `${B}projects` },
  { label: 'Papers', href: `${B}papers` },
  { label: 'Blog', href: `${B}blog` },
  { label: 'Milestones', href: `${B}milestones` },
  { label: 'Impossible List', href: `${B}impossible-list` },
  { label: 'Travels', href: `${B}travels` },
  { label: 'Contact', href: `${B}contact` },
];

const currentPath = Astro.url.pathname;
const containerClass = wide ? 'max-w-6xl' : 'max-w-3xl';

// JSON-LD Person schema — injected on every page so Google and LLMs
// can confidently associate this site with Merwan Birem.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Merwan Birem',
  url: `${SITE}${B}`,
  image: `${SITE}${B}og-image.png`,
  jobTitle: 'AI Innovation Leader & Senior Research Engineer',
  description: 'AI Innovation Leader with 10+ years of experience in computer vision, robotics, and industrial AI systems. Leading multi-million euro R&D programs at Flanders Make, Belgium.',
  worksFor: {
    '@type': 'Organization',
    name: 'Flanders Make',
    url: 'https://www.flandersmake.be',
  },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Université Clermont Auvergne (Blaise Pascal)', address: { '@type': 'PostalAddress', addressCountry: 'FR' } },
    { '@type': 'CollegeOrUniversity', name: 'National Polytechnic School of Algiers', address: { '@type': 'PostalAddress', addressCountry: 'DZ' } },
  ],
  knowsAbout: ['Computer Vision', 'Visual SLAM', 'Deep Learning', 'Industrial AI', 'Sensor Fusion', 'Pose Estimation', 'Robotics', 'MLOps', 'AI Workflow Automation'],
  nationality: { '@type': 'Country', name: 'Algeria' },
  address: { '@type': 'PostalAddress', addressLocality: 'Sterrebeek', addressCountry: 'BE' },
  sameAs: [
    'https://www.linkedin.com/in/merwan-birem-600a593a/',
    'https://scholar.google.com/citations?user=oikUY4YAAAAJ',
    'https://github.com/merwanbirem',
    'https://medium.com/@just-merwan',
    'https://github.com/Merwanski',
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary meta -->
    <title>{PAGE_TITLE}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Merwan Birem" />
    <meta name="keywords" content="Merwan Birem, AI, Computer Vision, Visual SLAM, Industrial AI, Flanders Make, Research Engineer, Belgium, Deep Learning, Robotics" />
    <link rel="canonical" href={CANONICAL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={CANONICAL} />
    <meta property="og:title" content={PAGE_TITLE} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${SITE}${B}og-image.png`} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Merwan Birem" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={PAGE_TITLE} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${SITE}${B}og-image.png`} />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <link rel="icon" type="image/svg+xml" href={`${B}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen flex flex-col">

    <header class="border-b border-[var(--color-border)] sticky top-0 bg-white/95 backdrop-blur-sm z-10">
      <div class={`${containerClass} mx-auto px-6 h-14 flex items-center justify-between`}>
        <a href={B} class="text-sm font-semibold tracking-tight text-[var(--color-ink)] hover:text-[var(--color-accent)] transition-colors">
          MB
        </a>
        <nav class="flex items-center gap-6">
          {nav.map(({ label, href }) => (
            <a
              href={href}
              class={`text-sm transition-colors ${
                currentPath === href || (href !== '/' && currentPath.startsWith(href))
                  ? 'text-[var(--color-accent)] font-medium'
                  : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]'
              }`}
            >
              {label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main class={`flex-1 ${containerClass} mx-auto w-full px-6 py-14`}>
      <slot />
    </main>

    <footer class="border-t border-[var(--color-border)] mt-auto">
      <div class={`${containerClass} mx-auto px-6 py-8 flex items-center justify-between text-xs text-[var(--color-faint)]`}>
        <span>© {new Date().getFullYear()} Merwan Birem</span>
        <span>Built with Astro · Hosted on GitHub Pages</span>
      </div>
    </footer>

  </body>
</html>
