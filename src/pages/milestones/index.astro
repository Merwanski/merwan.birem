---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allMilestones = await getCollection('milestones');
const sorted = allMilestones.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categoryColors: Record<string, string> = {
  professional: 'bg-blue-50 text-blue-600',
  academic: 'bg-violet-50 text-violet-600',
  personal: 'bg-emerald-50 text-emerald-600',
  travel: 'bg-amber-50 text-amber-600',
  family: 'bg-rose-50 text-rose-600',
};
---

<Layout title="Milestones" description="Personal and professional milestones — Merwan Birem">

  <div class="mb-12">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Milestones</h1>
    <p class="text-[var(--color-muted)]">
      Moments worth marking — personal, professional, academic, and everything in between.
    </p>
  </div>

  {sorted.length === 0 ? (
    <p class="text-[var(--color-muted)] text-sm italic">
      No milestones yet — drop an image or note into <code class="font-mono text-xs bg-zinc-100 px-1.5 py-0.5 rounded">inbox/milestones/</code> to add one.
    </p>
  ) : (
    <ol class="relative border-l border-[var(--color-border)] ml-3 space-y-10">
      {sorted.map(m => (
        <li class="ml-6">
          <span class="absolute -left-1.5 w-3 h-3 rounded-full bg-[var(--color-border)] border-2 border-white mt-1"></span>
          <div class="flex items-center gap-3 mb-1">
            <time class="text-xs font-mono text-[var(--color-faint)]">
              {m.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
            </time>
            <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${categoryColors[m.data.category] ?? 'bg-zinc-100 text-zinc-500'}`}>
              {m.data.category}
            </span>
          </div>
          <h2 class="text-base font-medium mb-1">{m.data.title}</h2>
          <p class="text-sm text-[var(--color-muted)]">{m.data.summary}</p>
        </li>
      ))}
    </ol>
  )}

</Layout>
