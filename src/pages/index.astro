---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const papers = await getCollection('papers', ({ data }) => data.featured);
const milestones = await getCollection('milestones', ({ data }) => data.featured);
---

<Layout title="Home">

  <!-- Identity -->
  <section class="mb-16">
    <h1 class="text-3xl font-semibold tracking-tight mb-2">Merwan Birem</h1>
    <p class="text-[var(--color-muted)] text-lg mb-6">
      Researcher &amp; Engineer
      <!-- Update: add current affiliation e.g. "· PhD Candidate at Université XYZ" -->
    </p>

    <p class="text-[var(--color-ink)] leading-relaxed max-w-2xl mb-4">
      <!-- Bio: paste your bio here, or drop your CV PDF into inbox/cv/ to auto-generate -->
      I work at the intersection of [research area 1] and [research area 2], with a focus on
      building systems that [core mission / what your work enables]. My background spans both
      academic research and applied engineering.
    </p>

    <p class="text-[var(--color-muted)] leading-relaxed max-w-2xl">
      Currently [role] at [organization]. Previously [previous role/institution].
    </p>
  </section>

  <!-- Links -->
  <section class="mb-16 flex flex-wrap gap-3">
    {[
      { label: 'LinkedIn', href: 'https://linkedin.com/in/merwan-birem', external: true },
      { label: 'CV / Résumé', href: '/cv.pdf', external: true },
      { label: 'Google Scholar', href: '#', external: true },
      { label: 'GitHub', href: 'https://github.com/merwanbirem', external: true },
      { label: 'Medium', href: '#', external: true },
    ].map(({ label, href, external }) => (
      <a
        href={href}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
        class="inline-flex items-center gap-1.5 text-sm px-3 py-1.5 border border-[var(--color-border)] rounded-md text-[var(--color-muted)] hover:text-[var(--color-accent)] hover:border-[var(--color-accent)] transition-colors"
      >
        {label}
        {external && (
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 opacity-60">
            <path d="M6.22 8.72a.75.75 0 0 0 1.06 1.06l5.22-5.22v1.69a.75.75 0 0 0 1.5 0v-3.5a.75.75 0 0 0-.75-.75h-3.5a.75.75 0 0 0 0 1.5h1.69L6.22 8.72Z" />
            <path d="M3.5 6.75c0-.69.56-1.25 1.25-1.25H7A.75.75 0 0 0 7 4H4.75A2.75 2.75 0 0 0 2 6.75v4.5A2.75 2.75 0 0 0 4.75 14h4.5A2.75 2.75 0 0 0 12 11.25V9a.75.75 0 0 0-1.5 0v2.25c0 .69-.56 1.25-1.25 1.25h-4.5c-.69 0-1.25-.56-1.25-1.25v-4.5Z" />
          </svg>
        )}
      </a>
    ))}
  </section>

  <!-- Research Interests -->
  <section class="mb-16">
    <h2 class="text-xs font-medium uppercase tracking-widest text-[var(--color-faint)] mb-5">Research Interests</h2>
    <ul class="space-y-2">
      {[
        '<!-- Add interest 1 -->',
        '<!-- Add interest 2 -->',
        '<!-- Add interest 3 -->',
      ].map(item => (
        <li class="flex items-start gap-2 text-[var(--color-muted)]">
          <span class="mt-2 w-1 h-1 rounded-full bg-[var(--color-faint)] shrink-0"></span>
          <span set:html={item} />
        </li>
      ))}
    </ul>
  </section>

  <!-- Featured Papers -->
  {papers.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xs font-medium uppercase tracking-widest text-[var(--color-faint)]">Selected Publications</h2>
        <a href="/papers" class="text-xs text-[var(--color-accent)] hover:underline">All papers →</a>
      </div>
      <ul class="space-y-6">
        {papers.map(paper => (
          <li>
            <a href={`/papers/${paper.id}`} class="group block">
              <p class="text-sm font-medium group-hover:text-[var(--color-accent)] transition-colors mb-1">
                {paper.data.title}
              </p>
              <p class="text-xs text-[var(--color-faint)]">
                {paper.data.authors.join(', ')} · {paper.data.year}
                {paper.data.venue && ` · ${paper.data.venue}`}
              </p>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- Featured Milestones -->
  {milestones.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-5">
        <h2 class="text-xs font-medium uppercase tracking-widest text-[var(--color-faint)]">Recent Milestones</h2>
        <a href="/milestones" class="text-xs text-[var(--color-accent)] hover:underline">All milestones →</a>
      </div>
      <ul class="space-y-4">
        {milestones.map(m => (
          <li class="flex items-start gap-4">
            <span class="text-xs text-[var(--color-faint)] font-mono pt-0.5 shrink-0">
              {m.data.date.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}
            </span>
            <span class="text-sm text-[var(--color-ink)]">{m.data.summary}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

</Layout>
