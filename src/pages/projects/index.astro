---
import Layout from '../../layouts/Layout.astro';

interface Project {
  name: string;
  years: string;
  role?: string;
  description?: string;
}

// Sorted newest first. years = range this project was active.
const projects: Project[] = [
  { name: 'QUALMA',                          years: '2021 – 2025', role: 'Researcher & Project Manager' },
  { name: 'RETAIN VILICON',                  years: '2024 – 2025' },
  { name: 'CNH B2B',                         years: '2023 – 2024' },
  { name: 'Depoortere B2B',                  years: '2024' },
  { name: 'PICANOL B2B',                     years: '2024' },
  { name: 'FROGS',                           years: '2021 – 2023' },
  { name: 'SMART VISION VIL',               years: '2022 – 2023' },
  { name: 'IcoTerminal B2B',                years: '2022 – 2023' },
  { name: 'Vision-Coock',                   years: '2022' },
  { name: 'DRONE-AI',                       years: '2021 – 2022' },
  { name: 'PILS',                           years: '2021' },
  { name: 'RELAI',                          years: '2021' },
  { name: 'Product Counting',               years: '2021' },
  { name: 'Box Counting v2',               years: '2021' },
  { name: 'FAMAR',                          years: '2019 – 2021' },
  { name: 'Vision Social Distancing (VSD)', years: '2020' },
  { name: 'Ventilator — VUB',              years: '2020' },
  { name: 'Smart Cobot',                   years: '2020' },
  { name: 'Inwaredrones ICON',             years: '2020' },
  { name: 'Smart Connectivity',            years: '2018 – 2020' },
  { name: 'Mobots',                        years: '2018 – 2020' },
  { name: 'Proceedix B2B',               years: '2019 – 2020' },
  { name: 'AVA B2B',                      years: '2019 – 2020' },
  { name: 'Albatros B2B',               years: '2019' },
  { name: 'P&G B2B',                    years: '2019' },
  { name: 'KOBI B2B',                   years: '2019' },
  { name: 'Smart Clamp Demo',           years: '2019' },
  { name: 'ViL — Vision in the Loop',  years: '2018' },
  { name: 'Opti-Drive',                years: '2018' },
  { name: 'DVS (Dynamic Vision Sensor)', years: '2018' },
  { name: 'HiL Setup',                 years: '2018' },
  { name: 'Indoor Drone Inspection',   years: '2017 – 2018' },
  { name: 'Locator',                   years: '2017 – 2018' },
  { name: 'Mecha 4.0 / P-Laser',      years: '2017 – 2018' },
  { name: 'Blind Spot Detection',      years: '2017' },
  { name: 'EMDAS',                     years: '2015 – 2017' },
  { name: 'GPOS',                      years: '2015 – 2017' },
];
---

<Layout title="Projects" description="Project portfolio of Merwan Birem — research and industrial AI projects from 2015 to present.">

  <div class="mb-12">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Projects</h1>
    <p class="text-[var(--color-muted)]">
      Research, industrial AI, and B2B projects — 2015 to present.
      Details are being added progressively.
    </p>
  </div>

  <ul class="space-y-3">
    {projects.map(({ name, years, role, description }) => (
      <li class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 py-3 border-b border-[var(--color-border)]">
        <span class="shrink-0 text-xs font-mono text-[var(--color-faint)] sm:w-28 pt-0.5">{years}</span>
        <div class="flex-1 min-w-0">
          <span class="text-sm font-medium text-[var(--color-ink)]">{name}</span>
          {role && (
            <span class="ml-2 text-xs text-[var(--color-accent)]">— {role}</span>
          )}
          <p class="text-sm text-[var(--color-faint)] italic mt-0.5">
            {description ?? 'Details to be added.'}
          </p>
        </div>
      </li>
    ))}
  </ul>

</Layout>
