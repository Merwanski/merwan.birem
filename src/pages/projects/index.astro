---

<Layout title="Projects" description="Project portfolio of Merwan Birem — research, B2B, and industrial AI projects from 2015 to present.">

  <div class="mb-12">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Projects</h1>
    <p class="text-[var(--color-muted)]">
      Research, industrial AI, and B2B projects — 2015 to present.
      Details are being added progressively.
    </p>
  </div>

  <div class="space-y-14">
    {timeline.map(({ year, entries }) => (
      <section>
        {/* Year heading */}
        <div class="flex items-center gap-4 mb-6">
          <span class="text-2xl font-bold tracking-tight text-[var(--color-ink)]">{year}</span>
          <div class="flex-1 h-px bg-[var(--color-border)]" />
        </div>

        <div class="space-y-6 pl-2">
          {entries.map(({ category, projects }) => (
            <div>
              {category && (
                <p class="text-xs font-medium uppercase tracking-widest text-[var(--color-faint)] mb-3">
                  {category}
                </p>
              )}
              <ul class="space-y-2">
                {projects.map(({ name, role }) => (
                  <li class="flex items-start gap-3 group">
                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] shrink-0 opacity-60" />
                    <div class="flex-1 min-w-0">
                      <span class="text-sm font-medium text-[var(--color-ink)]">{name}</span>
                      {role && (
                        <span class="ml-2 text-xs text-[var(--color-accent)]">— {role}</span>
                      )}
                      <span class="ml-2 text-xs text-[var(--color-faint)] italic">· details to be added</span>
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>
    ))}
  </div>

</Layout>
