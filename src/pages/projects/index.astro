<Layout title="Projects" description="Project portfolio of Merwan Birem — research and industrial AI projects from 2015 to present.">

  <div class="mb-10">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Projects</h1>
    <p class="text-[var(--color-muted)]">
      Research and industrial AI projects — 2015 to present.
      Details are being added progressively.
    </p>
  </div>

  <p class="text-xs font-medium uppercase tracking-widest text-[var(--color-faint)] mb-6">
    {projects.length} projects
  </p>

  <ul class="space-y-4">
    {projects.map(({ name, years, description, tags }) => (
      <li class="rounded-xl border border-[var(--color-border)] px-6 py-5 hover:border-zinc-300 transition-colors">
        <div class="flex items-start justify-between gap-4 mb-2">
          <h2 class="text-sm font-semibold text-[var(--color-ink)] leading-snug">{name}</h2>
          <span class="shrink-0 text-xs font-mono text-[var(--color-faint)] pt-0.5">{years}</span>
        </div>
        <p class={`text-sm leading-relaxed mb-3 ${description === 'Details to be added.' ? 'text-[var(--color-faint)] italic' : 'text-[var(--color-accent)]'}`}>
          {description}
        </p>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map(tag => (
              <span class="text-xs px-2.5 py-0.5 bg-zinc-100 text-zinc-500 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </li>
    ))}
  </ul>

</Layout>
