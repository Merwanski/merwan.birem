---
import Layout from '../../layouts/Layout.astro';
import { existsSync } from 'node:fs';
import cachedPosts from '../../data/medium-posts.json';

const USERNAME    = 'just-merwan';
const PROFILE_URL = `https://medium.com/@${USERNAME}`;
const RSS_URL     = `https://medium.com/feed/@${USERNAME}`;

interface Post {
  title: string;
  url: string;
  date: string;
  summary: string;
  tags: string[];
  readingTime?: string | null;
}

function parseMediumRSS(xml: string): Post[] {
  const items = [...xml.matchAll(/<item>([\s\S]*?)<\/item>/g)];
  return items.map(([, item]) => {
    const title =
      item.match(/<title><!\[CDATA\[([\s\S]*?)\]\]>/)?.[1]?.trim() ??
      item.match(/<title>([\s\S]*?)<\/title>/)?.[1]?.trim() ?? '';
    const rawUrl =
      item.match(/<link>(https?:\/\/[^<\s]+)<\/link>/)?.[1] ??
      item.match(/<guid[^>]*>(https?:\/\/[^<\s]+)<\/guid>/)?.[1] ?? '';
    const url = rawUrl.split('?')[0];
    const pubDate = item.match(/<pubDate>(.*?)<\/pubDate>/)?.[1] ?? '';
    const date    = pubDate ? new Date(pubDate).toISOString().split('T')[0] : '';
    const tags    = [...item.matchAll(/<category><!\[CDATA\[(.*?)\]\]>/g)].map(m => m[1]).slice(0, 4);
    const rawDesc = item.match(/<description><!\[CDATA\[([\s\S]*?)\]\]>/)?.[1] ?? '';
    const stripped = rawDesc
      .replace(/<[^>]+>/g, '')
      .replace(/&amp;/g, '&').replace(/&lt;/g, '<').replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#x[\da-f]+;/gi, c => String.fromCharCode(parseInt(c.slice(3, -1), 16)))
      .replace(/Continue reading on Medium\s*[»›]?/gi, '')
      .replace(/\s+/g, ' ').trim();
    const summary  = stripped.slice(0, 220) + (stripped.length > 220 ? '…' : '');
    const readingMatch = rawDesc.match(/(\d+)\s*min\s*read/i);
    return { title, url, date, summary, tags, readingTime: readingMatch ? `${readingMatch[1]} min` : null };
  }).filter(p => p.title && p.url);
}

// Use the synced JSON as primary source; fall back to live RSS if empty
let posts: Post[] = cachedPosts as Post[];
let liveError = false;

if (posts.length === 0) {
  try {
    const res = await fetch(RSS_URL, {
      headers: { 'User-Agent': 'MerwanBirem-site/1.0' },
    });
    if (res.ok) posts = parseMediumRSS(await res.text());
    else liveError = true;
  } catch {
    liveError = true;
  }
}

// Show the screenshot only after first sync has run (file is committed)
const hasScreenshot = existsSync('./public/medium-profile.png');
const synced = (cachedPosts as Post[]).length > 0;
---

<Layout title="Blog" description="Writing by Merwan Birem — research notes, engineering deep-dives, and reflections.">

  <div class="mb-8">
    <h1 class="text-2xl font-semibold tracking-tight mb-2">Blog</h1>
    <p class="text-[var(--color-muted)]">
      Writing hosted on{' '}
      <a href={PROFILE_URL} target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">
        Medium
      </a>.
      Research notes, engineering deep-dives, and reflections.
    </p>
  </div>

  {/* Profile screenshot — shown after first sync */}
  {hasScreenshot && (
    <a
      href={PROFILE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="block mb-10 rounded-xl overflow-hidden border border-[var(--color-border)] hover:border-zinc-300 transition-colors shadow-sm"
    >
      <img
        src="/medium-profile.png"
        alt="Merwan Birem on Medium"
        class="w-full object-cover object-top"
        style="max-height: 340px;"
      />
    </a>
  )}

  {/* Sync status badge */}
  <div class="flex items-center justify-between mb-8">
    <p class="text-xs text-[var(--color-faint)]">
      {synced
        ? `${posts.length} post${posts.length !== 1 ? 's' : ''} · synced from Medium`
        : 'Live from Medium RSS'}
    </p>
    <a
      href={PROFILE_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-[var(--color-accent)] hover:underline"
    >
      View on Medium →
    </a>
  </div>

  {posts.length === 0 ? (
    <p class="text-[var(--color-muted)] text-sm italic">
      {liveError
        ? 'Could not load posts right now — try again later.'
        : 'No posts published yet.'}
    </p>
  ) : (
    <ul class="space-y-10">
      {posts.map(post => (
        <li>
          <a href={post.url} target="_blank" rel="noopener noreferrer" class="group block">
            <div class="flex items-center gap-3 mb-2">
              {post.date && (
                <time class="text-xs text-[var(--color-faint)] font-mono">
                  {new Date(post.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </time>
              )}
              {post.readingTime && (
                <span class="text-xs text-[var(--color-faint)]">{post.readingTime} read</span>
              )}
            </div>
            <h2 class="text-base font-medium group-hover:text-[var(--color-accent)] transition-colors mb-1">
              {post.title}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="inline w-3 h-3 ml-1 opacity-40 group-hover:opacity-100 transition-opacity">
                <path d="M6.22 8.72a.75.75 0 0 0 1.06 1.06l5.22-5.22v1.69a.75.75 0 0 0 1.5 0v-3.5a.75.75 0 0 0-.75-.75h-3.5a.75.75 0 0 0 0 1.5h1.69L6.22 8.72Z" />
                <path d="M3.5 6.75c0-.69.56-1.25 1.25-1.25H7A.75.75 0 0 0 7 4H4.75A2.75 2.75 0 0 0 2 6.75v4.5A2.75 2.75 0 0 0 4.75 14h4.5A2.75 2.75 0 0 0 12 11.25V9a.75.75 0 0 0-1.5 0v2.25c0 .69-.56 1.25-1.25 1.25h-4.5c-.69 0-1.25-.56-1.25-1.25v-4.5Z" />
              </svg>
            </h2>
            {post.summary && (
              <p class="text-sm text-[var(--color-muted)] leading-relaxed">{post.summary}</p>
            )}
            {post.tags.length > 0 && (
              <div class="flex gap-2 mt-2 flex-wrap">
                {post.tags.map(tag => (
                  <span class="text-xs px-2 py-0.5 bg-zinc-100 text-zinc-500 rounded-full">{tag}</span>
                ))}
              </div>
            )}
          </a>
        </li>
      ))}
    </ul>
  )}

</Layout>
